{
  "family": "jambo-rafiki-web",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/jambo-rafiki-task-role",
  "containerDefinitions": [
    {
      "name": "web",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/jambo-rafiki-backend:<IMAGE_TAG>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "command": ["sh", "docker/entrypoint.sh"],
      "environment": [
        {"name": "DJANGO_ENV", "value": "production"},
        {"name": "DEBUG", "value": "False"},
        {"name": "ALLOWED_HOSTS", "value": "api.yourdomain.com"},
        {"name": "FRONTEND_URL", "value": "https://app.yourdomain.com"},
        {"name": "CORS_ALLOWED_ORIGINS", "value": "https://app.yourdomain.com"},
        {"name": "CSRF_TRUSTED_ORIGINS", "value": "https://app.yourdomain.com,https://api.yourdomain.com"},
        {"name": "USE_S3_MEDIA", "value": "True"},
        {"name": "AWS_STORAGE_BUCKET_NAME", "value": "your-prod-media-bucket"},
        {"name": "AWS_S3_REGION_NAME", "value": "af-south-1"},
        {"name": "AWS_MEDIA_LOCATION", "value": "media"},
        {"name": "AWS_S3_CUSTOM_DOMAIN", "value": "cdn.yourdomain.com"},
        {"name": "AWS_MEDIA_CACHE_CONTROL", "value": "max-age=86400"},
        {"name": "SECURE_SSL_REDIRECT", "value": "True"},
        {"name": "SESSION_COOKIE_SECURE", "value": "True"},
        {"name": "CSRF_COOKIE_SECURE", "value": "True"},
        {"name": "LOG_LEVEL", "value": "INFO"},
        {"name": "SECURITY_LOG_LEVEL", "value": "WARNING"},
        {"name": "SENTRY_TRACES_SAMPLE_RATE", "value": "0.05"}
      ],
      "secrets": [
        {"name": "SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/secret-key"},
        {"name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/database-url"},
        {"name": "EMAIL_BACKEND", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/email-backend"},
        {"name": "EMAIL_HOST", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/email-host"},
        {"name": "EMAIL_PORT", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/email-port"},
        {"name": "EMAIL_USE_TLS", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/email-use-tls"},
        {"name": "EMAIL_HOST_USER", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/email-user"},
        {"name": "EMAIL_HOST_PASSWORD", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/email-password"},
        {"name": "DEFAULT_FROM_EMAIL", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/default-from-email"},
        {"name": "ADMIN_EMAIL", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/admin-email"},
        {"name": "MPESA_CALLBACK_TOKEN", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/mpesa-callback-token"},
        {"name": "MPESA_CALLBACK_SIGNATURE_SECRET", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/mpesa-signature-secret"},
        {"name": "MPESA_CALLBACK_SIGNATURE_HEADER", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/mpesa-signature-header"},
        {"name": "STRIPE_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/stripe-secret-key"},
        {"name": "STRIPE_WEBHOOK_SECRET", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/stripe-webhook-secret"},
        {"name": "SENTRY_DSN", "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:prod/backend/sentry-dsn"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/jambo-rafiki-web",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/health/ || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
